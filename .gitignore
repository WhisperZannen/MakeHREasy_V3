# ==============================================================================
# MakeHREasy_V3 绝对安全隔离清单
# 作用：告诉 Git 哪些文件当做空气，绝对不允许进入版本库记录
# ==============================================================================

# 1. 拦截所有数据库文件 (这是包含真实员工档案的底座，绝对红线)
*.db
*.sqlite3

# 2. 拦截所有 Excel 文件 (防止真实的导入/导出表格、工资条被追踪)
*.xlsx
*.xls
*.csv

# 3. 拦截 Python 运行时产生的缓存垃圾
__pycache__/
*.pyc

# 4. 拦截虚拟环境文件夹 (存放第三方包的地方，没必要记录)
venv/
env/

# 5. 拦截系统或 IDE 自动生成的隐藏配置
.DS_Store
.idea/